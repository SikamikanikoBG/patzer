# Operational configuration only.
# Everything user-facing (Ollama URL, default model, language, Chess.com username,
# coach behavior, board theme, etc.) is configured through the app's UI
# (Admin Console for system settings, Settings page for per-profile preferences)
# and persisted in the SQLite database.

# HTTP server
PORT=8800
HOST=0.0.0.0

# Path to SQLite database file. Parent directory is created if missing.
DB_PATH=./data/chess.db

# Optional: explicit path to Stockfish binary. If unset, the server tries:
#   1. ./bin/stockfish.exe   (Windows local dev — run setup.ps1 to download)
#   2. /usr/games/stockfish  (Debian/Ubuntu/Docker default)
#   3. "stockfish" on PATH
# STOCKFISH_PATH=

# Cookie secret for signing session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Auto-generated and persisted to ./data/.session-secret on first run if unset.
# SESSION_SECRET=

# ---- Email (SMTP) — v7.7.0 ----
# Outgoing mail for signup verification, password resets and admin
# notifications. Everything here can ALSO be set from the UI (Admin → System →
# Email). When both are set, these environment variables win. Email is simply
# disabled (signup still works, just without verification/reset mails) until a
# host is configured.
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587            # 587/25 = STARTTLS (SMTP_SECURE=false); 465 = implicit TLS
#   SMTP_SECURE=false        # true only for port 465
#   SMTP_USER=you@example.com
#   SMTP_PASS=app-password   # keep secrets in env rather than the DB if you prefer
#   SMTP_FROM=Patzer <you@example.com>

# Public base URL used to build absolute links inside emails (verify / reset).
# Set this when the app sits behind a reverse proxy or a public hostname, so the
# links don't point at the internal Host header. Falls back to the request's
# own origin if unset. Can also be set from Admin → System.
#   PUBLIC_BASE_URL=http://ardi:8800
