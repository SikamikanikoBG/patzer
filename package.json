{
  "name": "patzer",
  "version": "7.5.0",
  "private": true,
  "description": "Patzer — your private Chess.com. Self-hosted, AI-coached, family-friendly. Stockfish + your own LLM in one Docker container.",
  "license": "MIT",
  "homepage": "https://github.com/SikamikanikoBG/patzer",
  "repository": {
    "type": "git",
    "url": "https://github.com/SikamikanikoBG/patzer.git"
  },
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"npm:dev -w server\" \"npm:dev -w web\"",
    "build": "npm run build -w server && npm run build -w web",
    "start": "npm run start -w server",
    "typecheck": "tsc -b server web --noEmit",
    "setup": "powershell -ExecutionPolicy Bypass -File ./setup.ps1"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.11"
  }
}
